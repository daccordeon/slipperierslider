  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ev", "[", 
   RowBox[{"l_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"p", "[", 
      RowBox[{"[", "j", "]"}], "]"}], 
     RowBox[{"l", "[", 
      RowBox[{"[", "j", "]"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", "1", ",", 
      RowBox[{"Length", "[", "l", "]"}]}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cov", "[", 
   RowBox[{"l1_", ",", "l2_", ",", "p_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"ev", "[", 
    RowBox[{
     RowBox[{"l1", " ", "l2"}], ",", "p"}], "]"}], "-", 
   RowBox[{
    RowBox[{"ev", "[", 
     RowBox[{"l1", ",", "p"}], "]"}], 
    RowBox[{"ev", "[", 
