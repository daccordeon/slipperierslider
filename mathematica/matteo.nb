 CellLabel->"In[35]:=",ExpressionUUID->"b25b9b70-2f06-48d9-9e0f-dd088ee922f3"],

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[CapitalSigma]", "=", 
     RowBox[{"\[CapitalSigma]\[LetterSpace]t1", "/.", 
      RowBox[{"\[Gamma]", "->", 
       SuperscriptBox["\[Theta]", "2"]}]}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Gamma]\[LetterSpace]purity", "=", 
     RowBox[{"FullSimplify", "[", 
      FractionBox["1", 
       SqrtBox[
        RowBox[{"Det", "[", 
         RowBox[{"2", " ", "\[CapitalSigma]"}], "]"}]]], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"QFI\[LetterSpace]SMSV", "=", 
     RowBox[{"FullSimplifyTimeConstrained", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"Tr", "[", 
         RowBox[{"MatrixPower", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Inverse", "[", "\[CapitalSigma]", "]"}], ".", 
            RowBox[{
             SubscriptBox["\[PartialD]", "\[Theta]"], "\[CapitalSigma]"}]}], 
           ",", "2"}], "]"}], "]"}], 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           SuperscriptBox["\[Gamma]\[LetterSpace]purity", "2"]}], ")"}]}]], 
       "+", 
       FractionBox[
        RowBox[{"2", " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["\[PartialD]", "\[Theta]"], 
            "\[Gamma]\[LetterSpace]purity"}], ")"}], "2"]}], 
        RowBox[{"1", "-", 
         SuperscriptBox["\[Gamma]\[LetterSpace]purity", "4"]}]]}], "]"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"QFI\[LetterSpace]SMSV", "=", 
     RowBox[{"QFI\[LetterSpace]SMSV", "/.", 
      RowBox[{"\[Theta]", "->", 
       RowBox[{"Sqrt", "[", "\[Gamma]", "]"}]}]}]}], ";"}]}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "purity", " ", "and", " ", "QFI", " ", "of", " ", "SMSV", " ", "are", " ",
      "verbose"}], ",", " ", 
    RowBox[{
    "but", " ", "perhaps", " ", "there", " ", "is", " ", "a", " ", "small", 
     " ", 
     RowBox[{"\[Gamma]", "/", "\[CapitalGamma]"}], " ", 
     RowBox[{"expansion", "?"}]}]}], "*)"}], "\[IndentingNewLine]", 
  "]"}]], "Input",
