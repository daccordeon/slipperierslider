Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "p", "]"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"p", "[", "n_", "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       FractionBox["\[Gamma]", "\[CapitalGamma]"]}], ")"}], 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox["\[Gamma]", "\[CapitalGamma]"], ")"}], "n"]}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p", "[", "n_", "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", "-", 
     FractionBox["\[Gamma]", "\[CapitalGamma]"]}], ")"}], 
   FractionBox[
    SuperscriptBox["\[Gamma]", "n"], 
    SuperscriptBox["\[CapitalGamma]", "n"]]}]}], "\[IndentingNewLine]", 
 RowBox[{"addToGlobalAssumptions", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Gamma]", ">", "0"}], ",", 
    RowBox[{"\[CapitalGamma]", ">", "0"}], ",", 
    RowBox[{"k", ">=", "0"}]}], "}"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"nbar", "=", 
  RowBox[{
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"n", " ", 
      RowBox[{"p", "[", "n", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "\[Infinity]"}], "}"}]}], "]"}], "//", 
   "FullSimplify"}]}], "\[IndentingNewLine]", 
 RowBox[{"QFI", "=", 
  RowBox[{
   RowBox[{"Sum", "[", 
    RowBox[{
     FractionBox[
      SuperscriptBox[
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"p", "[", "n", "]"}], ",", "\[Gamma]"}], "]"}], "2"], 
      RowBox[{"p", "[", "n", "]"}]], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "\[Infinity]"}], "}"}]}], "]"}], "//", 
   "FullSimplify"}]}]}], "Input",
