Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalSigma]\[LetterSpace]vac", "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"IdentityMatrix", "[", "4", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalSigma]\[LetterSpace]TMSV", "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", GridBox[{
       {
        RowBox[{"Cosh", "[", 
         RowBox[{"2", "r"}], "]"}], "0", 
        RowBox[{"Sinh", "[", 
         RowBox[{"2", "r"}], "]"}], "0"},
       {"0", 
        RowBox[{"Cosh", "[", 
         RowBox[{"2", "r"}], "]"}], "0", 
        RowBox[{"-", 
         RowBox[{"Sinh", "[", 
          RowBox[{"2", "r"}], "]"}]}]},
