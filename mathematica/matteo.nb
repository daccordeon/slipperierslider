Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Using", " ", 
    RowBox[{"ChatGPT", "'"}], "s", " ", "solution", " ", "to", " ", "the", 
    " ", "CM", " ", "evolution"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Kappa]", "=", 
     RowBox[{"\[CapitalGamma]", "-", "\[Gamma]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n\[Infinity]", "=", 
     FractionBox["\[Gamma]", "\[Kappa]"]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "\[CapitalSigma]\[LetterSpace]t0", "=", 
     "\[CapitalSigma]\[LetterSpace]SMSV"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalSigma]\[LetterSpace]t\[Infinity]", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        FractionBox["1", "2"], "+", "n\[Infinity]"}], ")"}], 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalSigma]\[LetterSpace]t1", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "\[Kappa]"}], " ", "t"}], "]"}], 
       "\[CapitalSigma]\[LetterSpace]t0"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "\[Kappa]"}], " ", "t"}], "]"}]}], ")"}], 
       "\[CapitalSigma]\[LetterSpace]t\[Infinity]"}]}]}], ";"}]}]}]], "Input",\

 CellGroupingRules->{"GroupTogetherGrouping", 10002.},
 CellChangeTimes->{
  3.966439468396504*^9, {3.966440560231588*^9, 3.966440570765696*^9}, 
