Cell[CellGroupData[{

Cell["Coherent expansion, dead time; also gain estimation", "Text",
 CellGroupingRules->{"GroupTogetherGrouping", 10005.},
 CellChangeTimes->{{3.987081866506886*^9, 3.987081870611224*^9}, {
  3.987085335500915*^9, 
  3.987085353307983*^9}},ExpressionUUID->"875eeb77-3a53-425b-9d62-\
c9d2319a539e"],

Cell[BoxData[{
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"Series", "[", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       RowBox[{"Sech", "[", 
        RowBox[{"k", " ", 
         RowBox[{"t", "/", "4"}]}], "]"}], "2"], "/.", 
      RowBox[{"t", "->", 
       RowBox[{"2", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"3", 
           RowBox[{"\[Tau]", "/", 
            SuperscriptBox["k", "2"]}]}], ")"}], 
