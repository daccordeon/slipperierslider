Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "vacuum", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"vacvals", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Nbar", "->", "0"}], ",", " ", 
       RowBox[{"\[Kappa]", "->", 
        RowBox[{"1", "/", "100."}]}], 
       RowBox[{"(*", 
        RowBox[{"us", "^", 
         RowBox[{"-", "1"}]}], "*)"}], ",", 
       RowBox[{"\[Tau]", "->", "200."}], 
       RowBox[{"(*", "us", "*)"}], ",", 
       RowBox[{"\[Gamma]", "->", 
        FractionBox[
         RowBox[{"1", "/", "100."}], "1000"]}]}], 
      RowBox[{"(*", 
       RowBox[{"us", "^", 
        RowBox[{"-", "1"}]}], "*)"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"snr2vac", "=", 
    RowBox[{
     FractionBox[
      RowBox[{"\[Gamma]", " ", "T"}], 
      RowBox[{"t", "+", "\[Tau]"}]], "qfi8"}]}], "\[IndentingNewLine]", 
   RowBox[{"snr2Nvac", "=", 
    RowBox[{"snr2vac", "/.", "vacvals"}]}], "\[IndentingNewLine]", 
   RowBox[{"solvac", "=", 
