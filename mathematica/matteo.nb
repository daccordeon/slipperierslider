Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Kappa]", "=", 
   RowBox[{"\[CapitalGamma]", "-", "\[Gamma]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Nb", "=", 
   FractionBox["\[Gamma]", "\[Kappa]"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Eta]", "=", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "\[Kappa]"}], " ", "t"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"\[Eta]dSqr", "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"\[Eta]", "/.", 
        RowBox[{"\[Gamma]", "->", 
         SuperscriptBox["s", "2"]}]}], ",", "s"}], "]"}], "2"], "/.", 
    RowBox[{"s", "->", 
     RowBox[{"Sqrt", "[", "\[Gamma]", "]"}]}]}], "//", 
   "FullSimplify"}]}], "\[IndentingNewLine]", 
 RowBox[{"NbdSqr", "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"Nb", "/.", 
        RowBox[{"\[Gamma]", "->", 
         SuperscriptBox["s", "2"]}]}], ",", "s"}], "]"}], "2"], "/.", 
    RowBox[{"s", "->", 
     RowBox[{"Sqrt", "[", "\[Gamma]", "]"}]}]}], "//", 
   "FullSimplify"}]}]}], "Input",
