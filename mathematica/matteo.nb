Cell[BoxData[{
 RowBox[{"addToGlobalAssumptions", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Gamma]", ">", "0"}], ",", 
    RowBox[{"\[CapitalGamma]", ">", "0"}], ",", 
    RowBox[{"\[CapitalGamma]", ">", "\[Gamma]"}], ",", 
    RowBox[{"t", ">", "0"}], ",", 
    RowBox[{"r", ">", "0"}]}], "}"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalSigma]\[LetterSpace]vac", "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalSigma]\[LetterSpace]SMSV", "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", GridBox[{
       {
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "2"}], "r"}], "]"}], "0"},
       {"0", 
        RowBox[{"Exp", "[", 
         RowBox[{"2", "r"}], "]"}]}
      }], ")"}]}]}], ";"}]}], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 10002.},
