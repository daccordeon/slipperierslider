Cell[BoxData[{
 RowBox[{
  RowBox[{"plot\[LetterSpace]Fock", "[", "\[Eta]0_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Eta]", "=", "\[Eta]0"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"data", "=", 
      RowBox[{"Table", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"n", ",", 
          RowBox[{"QFI", "[", "n", "]"}], ",", 
          RowBox[{"prev", "[", "n", "]"}], ",", 
          FractionBox["2", "\[Eta]"], ",", 
          FractionBox["2", 
           RowBox[{"\[Eta]", " ", "E"}]], ",", 
          FractionBox["1", "\[Eta]"]}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"n", ",", "0", ",", "50"}], "}"}]}], "\[IndentingNewLine]", 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"fold\[LetterSpace]data2", "[", "data", "]"}], ","}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       AdjustmentBox[
        RowBox[{"fold\[LetterSpace]data2", "[", 
         RowBox[{"N", "[", 
          RowBox[{"data", ",", "100"}], "]"}], "]"}],
        BoxMargins->{{-0.0950048244637423, 0.0950048244637423}, {0., 0.}}], 
       AdjustmentBox[",",
        BoxMargins->{{-0.0950048244637423, 0.0950048244637423}, {0., 0.}}], 
       "\[IndentingNewLine]", 
       RowBox[{"Joined", "->", "True"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{"0", ",", "All"}], "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<n\>\"", ",", "\"\<QFI\>\""}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"\"\<\[Eta] = \>\"", "<>", 
         RowBox[{"ToString", "[", "\[Eta]", "]"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Deterministic\>\"", ",", 
          "\"\<First term (equiv. to rand., small signal)\>\"", ",", 
          "\"\<ECQFI\>\"", ",", 
          "\"\<Fock loose approximation for rand., small signal\>\"", ",", 
          "\"\<Half ECQFI\>\""}], "}"}]}]}], "\[IndentingNewLine]", "]"}]}]}],
