Cell[BoxData[{
 RowBox[{"Clear", "[", "lazy\[LetterSpace]QFI", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lazy\[LetterSpace]QFI", "[", 
   RowBox[{"\[Rho]_", ",", "\[Theta]_", ",", 
    RowBox[{"conjRule_", ":", 
     RowBox[{"{", "}"}]}], ",", 
    RowBox[{"simplify_", ":", "FullSimplify"}]}], "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Lazy", " ", "form", " ", "of", " ", "the", " ", "QFI", " ", "which", 
      " ", "will", " ", "progress", " ", "so", " ", "long", " ", "as", " ", 
      "it", " ", "knows", " ", "that", " ", "the", " ", "sum", " ", "of", " ",
       "eigenvalues", " ", "is", " ", "not", " ", "immediately", " ", 
      "symbolically", " ", "zero"}], ",", " ", 
     RowBox[{
     "and", " ", "will", " ", "store", " ", "the", " ", "assumed", " ", 
      "nonzero", " ", "quantities", " ", "in", " ", "a", " ", "separate", " ",
       "list", " ", "that", " ", "it", " ", 
      RowBox[{"returns", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"d", "=", 
     RowBox[{"Length", "[", "\[Rho]", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"\[Lambda]s", "=", 
     RowBox[{"Eigenvalues", "[", "\[Rho]", "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"\[Psi]s", "=", 
     RowBox[{"EigenvectorsNormalised", "[", "\[Rho]", "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"\[Psi]sConj", "=", 
     RowBox[{"\[Psi]s", "/.", "conjRule"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"\[Rho]dot", "=", 
     RowBox[{"D", "[", 
      RowBox[{"\[Rho]", ",", "\[Theta]"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"assumed\[LetterSpace]nonzero", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Fq", "=", 
     RowBox[{
      RowBox[{"Sum", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"sum\[LetterSpace]of\[LetterSpace]evals", "=", 
            RowBox[{
             RowBox[{"\[Lambda]s", "[", 
              RowBox[{"[", "j", "]"}], "]"}], "+", 
             RowBox[{"\[Lambda]s", "[", 
              RowBox[{"[", "k", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
           
           RowBox[{"sum\[LetterSpace]of\[LetterSpace]evals", "===", "0"}]}], 
          ",", "\[IndentingNewLine]", "0", ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"AppendTo", "[", 
            RowBox[{
            "assumed\[LetterSpace]nonzero", ",", 
             "sum\[LetterSpace]of\[LetterSpace]evals"}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            FractionBox["2", "sum\[LetterSpace]of\[LetterSpace]evals"], 
            "\[IndentingNewLine]", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"\[Psi]sConj", "[", 
               RowBox[{"[", "j", "]"}], "]"}], ".", "\[Rho]dot", ".", 
              RowBox[{"\[Psi]s", "[", 
               RowBox[{"[", "k", "]"}], "]"}]}], ")"}], "\[IndentingNewLine]", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"\[Psi]sConj", "[", 
               RowBox[{"[", "k", "]"}], "]"}], ".", "\[Rho]dot", ".", 
              RowBox[{"\[Psi]s", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], ")"}]}]}]}], 
         "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "d"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", "d"}], "}"}]}], "\[IndentingNewLine]", 
       "]"}], "//", "simplify"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Return", "[", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<QFI\>\"", "\[Rule]", "Fq"}], ",", 
       RowBox[{
       "\"\<assumed nonzero\>\"", "\[Rule]", 
        "assumed\[LetterSpace]nonzero"}]}], "|>"}], "]"}]}], 
   "\[IndentingNewLine]", ")"}]}]}], "Input",
