    RowBox[{"EVSqr", "=", 
     RowBox[{
      RowBox[{"ConjugateTranspose", "[", "ket1", "]"}], ".", "op", ".", "op", 
      ".", "ket1"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Var", "=", 
     RowBox[{
      RowBox[{"EVSqr", "-", 
       SuperscriptBox["EV", "2"]}], "//", "FullSimplify"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"Var", ",", "EVSqr", ",", "EV"}], "}"}], "]"}], ";"}], "*)"}],
     "\[IndentingNewLine]", 
    RowBox[{"Return", "[", "Var", "]"}], ";"}], "\[IndentingNewLine]", 
   ")"}]}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "sumOfVars", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sumOfVars", "[", 
   RowBox[{"d_", ",", "ket_", ",", 
    RowBox[{"print_", ":", "False"}]}], "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"each", "=", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"var", "[", 
         RowBox[{"ket", ",", 
          RowBox[{"Sx", "[", "d", "]"}]}], "]"}], ",", 
        RowBox[{"var", "[", 
         RowBox[{"ket", ",", 
          RowBox[{"Sy", "[", "d", "]"}]}], "]"}], ",", 
        RowBox[{"var", "[", 
         RowBox[{"ket", ",", 
          RowBox[{"Sz", "[", "d", "]"}]}], "]"}]}], "}"}], "//", 
      "Simplify"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"total", "=", 
     RowBox[{
      RowBox[{"Total", "[", "each", "]"}], "//", "Simplify"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{"print", ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Print", "[", 
