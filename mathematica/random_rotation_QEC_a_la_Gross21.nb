      "Jz", " ", "eigenstate", " ", "with", " ", "eigenvalue", " ", "j", " ", 
       "of", " ", "spin"}], "-", 
      RowBox[{
       RowBox[{"d", "/", "2"}], " ", "system"}]}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"state", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"dummy", ",", "1", ",", 
          RowBox[{"d", "+", "1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"state", "[", 
       RowBox[{"[", "j", "]"}], "]"}], "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"d", "/", "2"}], ",", 
          RowBox[{
           RowBox[{"d", "/", "2"}], "-", 
