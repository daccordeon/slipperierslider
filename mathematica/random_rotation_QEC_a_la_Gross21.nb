Cell[BoxData[{
 RowBox[{
  RowBox[{"addToGlobalAssumptions", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", ">=", "0"}], ",", 
     RowBox[{"d", ">=", "1"}]}], "}"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]", "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", GridBox[{
       {
        RowBox[{"1", "+", 
         SuperscriptBox["\[Eta]", "d"]}], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", "\[Eta]"}], ")"}], 
         RowBox[{"d", "/", "2"}]]},
       {
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", "\[Eta]"}], ")"}], 
         RowBox[{"d", "/", "2"}]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", "\[Eta]"}], ")"}], "d"]}
      }], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Eigensystem", "[", "\[Rho]", "]"}], "//", 
  "FullSimplify"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"%", "/.", 
   RowBox[{"\[Eta]", "->", "0"}]}], "//", "FullSimplify"}]}], "Input",
