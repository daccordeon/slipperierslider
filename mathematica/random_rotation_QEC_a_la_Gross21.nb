Cell["\<\
Sensing Z dephasing in the presence of loss, spin d/2 system (have I already \
studied this?)\
\>", "Text",
 CellChangeTimes->{{3.926083505940652*^9, 
  3.926083521087821*^9}},ExpressionUUID->"9affa9e9-53b5-4021-85c7-\
53b4f44883d6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"from", " ", "random_rotations"}], ",", " ", 
    RowBox[{"note", " ", "EigenvaluesNormalised"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Clear", "[", "QFI", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"QFI", "[", 
     RowBox[{"\[Rho]_", ",", "\[Theta]_", ",", 
      RowBox[{"conjRule_", ":", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"simplify_", ":", "FullSimplify"}]}], "]"}], ":=", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "strict", " ", "form", " ", "of", " ", "the", " ", "QFI", " ", "which",
         " ", "will", " ", "only", " ", "progress", " ", "if", " ", "it", " ",
         "knows", " ", "that", " ", "the", " ", "sum", " ", "of", " ", 
        "eigenvalues", " ", "is", " ", "non"}], "-", 
       RowBox[{"zero", "."}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"d", "=", 
       RowBox[{"Length", "[", "\[Rho]", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Lambda]s", "=", 
       RowBox[{"Eigenvalues", "[", "\[Rho]", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Psi]s", "=", 
       RowBox[{"EigenvectorsNormalised", "[", "\[Rho]", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Psi]sConj", "=", 
       RowBox[{"\[Psi]s", "/.", "conjRule"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Rho]dot", "=", 
       RowBox[{"D", "[", 
        RowBox[{"\[Rho]", ",", "\[Theta]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Fq", "=", 
       RowBox[{
        RowBox[{"Sum", "[", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          FractionBox[
           RowBox[{"4", 
            RowBox[{"\[Lambda]s", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"\[Lambda]s", "[", 
               RowBox[{"[", "j", "]"}], "]"}], "+", 
              RowBox[{"\[Lambda]s", "[", 
               RowBox[{"[", "k", "]"}], "]"}]}], ")"}], "2"]], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"\[Lambda]s", "[", 
               RowBox[{"[", "j", "]"}], "]"}], "+", 
              RowBox[{"\[Lambda]s", "[", 
               RowBox[{"[", "k", "]"}], "]"}]}], "\[Equal]", "0"}], 
            RowBox[{"(*", 
             RowBox[{"//", "FullSimplify"}], "*)"}], ",", 
            "\[IndentingNewLine]", "0", ",", "\[IndentingNewLine]", 
            RowBox[{
             FractionBox["2", 
              RowBox[{
               RowBox[{"\[Lambda]s", "[", 
                RowBox[{"[", "j", "]"}], "]"}], "+", 
               RowBox[{"\[Lambda]s", "[", 
