  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"d", "/", "2"}], "+", "1", "-", "JzEval"}], "=", "j"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "dicke", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dicke", "[", 
