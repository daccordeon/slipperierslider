       RowBox[{"Print", "[", 
        RowBox[{
         RowBox[{"total", "//", "N"}], ",", 
         RowBox[{"each", "//", "N"}]}], "]"}], ";"}]}], "\[IndentingNewLine]",
      "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Return", "[", "total", "]"}], ";"}], "\[IndentingNewLine]", 
   ")"}]}]}], "Input",
