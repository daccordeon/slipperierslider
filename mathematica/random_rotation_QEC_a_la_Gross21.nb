Cell[BoxData[{
 RowBox[{"Clear", "[", "maxminKet", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"maxminKet", "[", 
    RowBox[{"d_", ",", "\[Phi]_"}], "]"}], ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"Sqrt", "[", "2", "]"}]], 
      RowBox[{"dicke", "[", 
       RowBox[{
        RowBox[{"d", "/", "2"}], ",", 
        RowBox[{"d", "/", "2"}]}], "]"}]}], "\[IndentingNewLine]", "+", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "\[Phi]"}], "]"}], 
      FractionBox["1", 
       RowBox[{"Sqrt", "[", "2", "]"}]], 
      RowBox[{"dicke", "[", 
       RowBox[{
        RowBox[{"d", "/", "2"}], ",", 
        RowBox[{
         RowBox[{"-", "d"}], "/", "2"}]}], "]"}]}]}], "\[IndentingNewLine]", 
    ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "compareToUB", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"compareToUB", "[", "d_", "]"}], ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"sumV", "=", 
      RowBox[{
       RowBox[{"sumOfVars", "[", 
        RowBox[{"d", ",", 
         RowBox[{"maxminKet", "[", 
          RowBox[{"d", ",", 
           RowBox[{"(*", "\[Phi]", "*)"}], "0"}], "]"}], ",", "True"}], "]"}],
        "//", "Simplify"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"UB", "=", 
      RowBox[{"d", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"d", "+", "2"}], ")"}], "/", "4"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Upper bound: \>\"", ",", "UB", ",", "\"\<, \>\"", ",", 
       RowBox[{"UB", "//", "N"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Saturates the bound: \>\"", ",", 
       RowBox[{
        RowBox[{"UB", "==", "sumV"}], "//", "Simplify"}]}], "]"}], ";"}], 
    "\[IndentingNewLine]", ")"}]}], ";"}]}], "Input",
