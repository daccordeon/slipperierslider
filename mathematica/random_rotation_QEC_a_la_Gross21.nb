        RowBox[{"d", "+", "1"}]}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Sx", "[", "d_", "]"}], ":=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"KroneckerDelta", "[", 
          RowBox[{"j", ",", 
           RowBox[{"k", "+", "1"}]}], "]"}], "+", 
         RowBox[{"KroneckerDelta", "[", 
          RowBox[{
           RowBox[{"j", "+", "1"}], ",", "k"}], "]"}]}], ")"}], 
       "\[IndentingNewLine]", 
