        RowBox[{"k", ",", "1", ",", 
         RowBox[{"d", "+", "1"}]}], "}"}]}], "\[IndentingNewLine]", "]"}]}]}],
    ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "observe", " ", "the", " ", "commutation", " ", "relations", " ", "and", 
    " ", "thus", " ", "the", " ", "factor", " ", "of", " ", "sqrt2", " ", 
    "here", " ", "is", " ", "dropped"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Splus", "[", "d_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Sx", "[", "d", "]"}], "+", 
