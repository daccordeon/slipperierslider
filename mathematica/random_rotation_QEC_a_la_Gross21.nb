 RowBox[{
  RowBox[{"norm", "[", 
   RowBox[{"d_", ",", "ket_"}], "]"}], ":=", 
  RowBox[{"Sqrt", "[", 
   RowBox[{"Total", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"Abs", "[", 
        RowBox[{"ket", "[", 
         RowBox[{"[", "j", "]"}], "]"}], "]"}], "2"], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", 
        RowBox[{"d", "+", "1"}]}], "}"}]}], "]"}], "]"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"normalise", "[", 
    RowBox[{"d_", ",", "ket_"}], "]"}], ":=", 
   RowBox[{"ket", "/", 
    RowBox[{"norm", "[", 
     RowBox[{"d", ",", "ket"}], "]"}]}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", 
  RowBox[{"Sx", ",", "Sy", ",", "Sz"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
