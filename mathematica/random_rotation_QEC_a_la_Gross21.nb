  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Sy", "[", "d_", "]"}], ":=", 
    RowBox[{
     FractionBox["I", "2"], 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"j", ",", 
            RowBox[{"k", "+", "1"}]}], "]"}], "-", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{
            RowBox[{"j", "+", "1"}], ",", "k"}], "]"}]}], ")"}], 
        "\[IndentingNewLine]", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"d", "/", "2"}], "+", "1"}], ")"}], 
