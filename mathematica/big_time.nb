Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"g", "=", "1"}], ",", 
       RowBox[{"n", "=", "5"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{
             RowBox[{"Binomial", "[", 
              RowBox[{"n", ",", "k"}], "]"}], 
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{
               RowBox[{"-", "g"}], " ", "n", " ", "t", " "}]], 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "1"}], "+", 
                SuperscriptBox["\[ExponentialE]", 
                 RowBox[{"g", " ", "t"}]]}], ")"}], "k"]}]}], " ", "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], "]"}], "//", 
        "Evaluate"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}]}]}], "\[IndentingNewLine]", "]"}]}], 
    "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"t", ",", 
     FractionBox[
      RowBox[{"1", "/", "10"}], 
      RowBox[{"g", " ", "n"}]], ",", 
     FractionBox["10", 
      RowBox[{"g", " ", "n"}]]}], "}"}]}], "]"}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 10003.},
