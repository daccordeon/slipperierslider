Cell[BoxData[{
 RowBox[{"addToGlobalAssumptions", "[", 
  RowBox[{"{", 
   RowBox[{"g", ">=", "0"}], "}"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", "p", "]"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"p", "[", 
     RowBox[{"n_", ",", "k_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"Binomial", "[", 
      RowBox[{"n", ",", "k"}], "]"}], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "g"}], " ", "n", " ", "t", " "}]], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"g", " ", "t"}]]}], ")"}], "k"]}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p", "[", 
   RowBox[{"n_", ",", "k_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Binomial", "[", 
    RowBox[{"n", ",", "k"}], "]"}], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["u", "2"]}], " ", "n", " ", "t", " "}]], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        SuperscriptBox["u", "2"], " ", "t"}]]}], ")"}], 
    "k"]}]}], "\[IndentingNewLine]", 
 RowBox[{"Sum", "[", 
  RowBox[{
   RowBox[{"p", "[", 
    RowBox[{"n", ",", "k"}], "]"}], " ", ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"QFI", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"p", "[", 
           RowBox[{"n", ",", "k"}], "]"}], ",", "u"}], "]"}], "2"], 
       RowBox[{"p", "[", 
        RowBox[{"n", ",", "k"}], "]"}]], " ", ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], "]"}], "/.", 
    RowBox[{
     SuperscriptBox["u", "2"], "->", "g"}]}], "//", 
   "FullSimplify"}]}], "\[IndentingNewLine]", 
 RowBox[{"Series", "[", 
  RowBox[{"QFI", ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "3"}], "}"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Series", "[", 
  RowBox[{"QFI", ",", 
   RowBox[{"{", 
    RowBox[{"g", ",", "0", ",", "3"}], "}"}]}], "]"}]}], "Input",
