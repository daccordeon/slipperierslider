Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "define", " ", "ladder", " ", "operators", " ", "and", " ", "derived", 
     " ", "operators"}], ",", " ", 
    RowBox[{
    "automatically", " ", "sorts", " ", "into", " ", "the", " ", "REVERSED", 
     " ", "order", " ", "of", " ", "the", " ", "list"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"modes", "=", 
     RowBox[{"{", 
      RowBox[{
       OverscriptBox["c", "^"], ",", 
       OverscriptBox["b", "^"], ",", 
       OverscriptBox["a", "^"], ",", 
       SuperscriptBox[
        OverscriptBox["a", "^"], "\[Dagger]"], ",", 
       SuperscriptBox[
        OverscriptBox["b", "^"], "\[Dagger]"], ",", 
       SuperscriptBox[
        OverscriptBox["c", "^"], "\[Dagger]"]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"listThatCommute", "[", "modes", "]"}], "\[IndentingNewLine]", 
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{"commutator", "[", 
      RowBox[{
       RowBox[{"modes", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", 
       SuperscriptBox[
        RowBox[{"modes", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "\[Dagger]"], ",", "1"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{
        RowBox[{"Length", "[", "modes", "]"}], "/", "2"}]}], "}"}]}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     OverscriptBox["xa", "^"], "=", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"Sqrt", "[", "2", "]"}]], 
      RowBox[{"(", 
       RowBox[{
        OverscriptBox["a", "^"], "+", 
        SuperscriptBox[
         OverscriptBox["a", "^"], "\[Dagger]"]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     OverscriptBox["xb", "^"], "=", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"Sqrt", "[", "2", "]"}]], 
      RowBox[{"(", 
       RowBox[{
        OverscriptBox["b", "^"], "+", 
        SuperscriptBox[
         OverscriptBox["b", "^"], "\[Dagger]"]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     OverscriptBox["xc", "^"], "=", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"Sqrt", "[", "2", "]"}]], 
      RowBox[{"(", 
       RowBox[{
        OverscriptBox["c", "^"], "+", 
        SuperscriptBox[
         OverscriptBox["c", "^"], "\[Dagger]"]}], ")"}]}]}], 
    ";"}]}]}]], "Input",
