Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "\[Psi]", " ", "is", " ", "the", " ", "initial", " ", "state", " ", "of", 
     " ", "modes", " ", "1"}], ",", " ", "2", ",", " ", 
    RowBox[{"3", ";", "\[IndentingNewLine]", 
     RowBox[{
     "initial", " ", "state", " ", "of", " ", "mode", " ", "1", " ", "is", 
      " ", "unknown"}], ";", 
     RowBox[{
     "but", " ", "the", " ", "initial", " ", "state", " ", "of", " ", "modes",
       " ", "2", " ", "and", " ", "3", " ", "is", " ", "vacuum"}], ";"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"contraction", "[", 
    RowBox[{
     SubscriptBox[
      OverscriptBox["bra", "^"], "\[Psi]"], ",", 
     SubscriptBox[
      OverscriptBox["ket", "^"], "\[Psi]"], ",", "1"}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{"contraction", "[", 
    RowBox[{
     OverscriptBox["b", "^"], ",", 
     SubscriptBox[
      OverscriptBox["ket", "^"], "\[Psi]"], ",", "0"}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{"contraction", "[", 
    RowBox[{
     OverscriptBox["c", "^"], ",", 
     SubscriptBox[
      OverscriptBox["ket", "^"], "\[Psi]"], ",", "0"}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nbarRule", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"op", "[", 
        RowBox[{
         RowBox[{"Operator", "[", 
          RowBox[{"bra", ",", "\[Psi]"}], "]"}], ",", 
         RowBox[{"SuperDagger", "[", 
          RowBox[{"Operator", "[", "a", "]"}], "]"}], ",", 
         RowBox[{"Operator", "[", "a", "]"}], ",", 
         RowBox[{"Operator", "[", 
          RowBox[{"ket", ",", "\[Psi]"}], "]"}]}], "]"}], "->", "nbar"}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{"ev", ",", "var"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ev", "[", 
     RowBox[{"expr_", ",", 
      RowBox[{"simplify_", ":", "True"}]}], "]"}], ":=", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"result", "=", 
       RowBox[{
        SubscriptBox[
         OverscriptBox["bra", "^"], "\[Psi]"], "\[SmallCircle]", "expr", 
        "\[SmallCircle]", 
        SubscriptBox[
         OverscriptBox["ket", "^"], "\[Psi]"]}]}], ";", 
      RowBox[{"(*", 
       RowBox[{
       "write", " ", "this", " ", "explicitly", " ", "instead", " ", "of", 
        " ", "as", " ", 
        TemplateBox[{"\[Psi]"},
         "Ket"], " ", "since", " ", "it", " ", "otherwise", " ", "breaks"}], 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{"simplify", ",", "\[IndentingNewLine]", 
         RowBox[{"result", "//", "FullSimplifyTimeConstrained"}], ",", 
         "\[IndentingNewLine]", "result"}], "\[IndentingNewLine]", "]"}], 
       "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", ")"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"var", "[", 
     RowBox[{"expr_", ",", 
      RowBox[{"simplify_", ":", "True"}]}], "]"}], ":=", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"result1", "=", 
       RowBox[{
        RowBox[{"ev", "[", 
         RowBox[{
          RowBox[{"pow", "[", 
           RowBox[{"expr", ",", "2"}], "]"}], ",", "False"}], "]"}], "-", 
        RowBox[{
         RowBox[{"ev", "[", 
          RowBox[{"expr", ",", "False"}], "]"}], "^", "2"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{"simplify", ",", "\[IndentingNewLine]", 
         RowBox[{"result1", "//", "FullSimplifyTimeConstrained"}], ",", 
         "\[IndentingNewLine]", "result1"}], "\[IndentingNewLine]", "]"}], 
       "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
     ")"}]}]}]}]], "Input",
